{
  "entities": {
    "UserToken": {
      "title": "UserToken",
      "description": "Stores FCM tokens for users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The user's ID." },
        "token": { "type": "string", "description": "The FCM token." }
      },
      "required": ["userId", "token"]
    }
  },
  "firestore": {
    "/userTokens/{tokenId}": {
      "schema": "UserToken",
      "description": "Collection of FCM tokens."
    }
  }
}
